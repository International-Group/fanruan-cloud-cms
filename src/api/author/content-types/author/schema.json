{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Author"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "desc": {
      "type": "text"
    },
    "cover": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "social": {
      "type": "component",
      "component": "shared.social",
      "repeatable": true
    },
    "insights": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::insight.insight"
    },
    "pop_cta_style": {
      "type": "integer",
      "default": 5
    }
  }
}

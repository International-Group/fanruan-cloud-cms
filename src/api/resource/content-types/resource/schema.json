{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "banner": {
      "type": "component",
      "component": "shared.banner",
      "repeatable": false,
      "required": true
    },
    "content": {
      "type": "richtext"
    },
    "cta": {
      "type": "component",
      "component": "shared.cta",
      "repeatable": false
    },
    "glossary": {
      "type": "component",
      "component": "shared.glossary",
      "repeatable": true
    },
    "resource": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "On-Demand Webinar",
        "Solution Brief",
        "Whitepaper"
      ]
    },
    "industry": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Manufacturing",
        "Financial Services",
        "Public Sector",
        "Retail"
      ]
    },
    "video": {
      "type": "string"
    }
  }
}
